<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Material Classification Challenge</title>
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        
        body {
            background: linear-gradient(135deg, #2c3e50, #4a6491);
            color: #fff;
            min-height: 100vh;
            padding: 20px;
            display: flex;
            justify-content: center;
            align-items: center;
        }
        
        .container {
            max-width: 800px;
            width: 100%;
            background: rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(10px);
            border-radius: 20px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
            overflow: hidden;
            padding: 30px;
        }
        
        header {
            text-align: center;
            margin-bottom: 30px;
        }
        
        h1 {
            font-size: 2.5rem;
            margin-bottom: 10px;
            background: linear-gradient(to right, #4facfe, #00f2fe);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            text-shadow: 0 2px 4px rgba(0, 0, 0, 0.2);
        }
        
        .subtitle {
            font-size: 1.2rem;
            opacity: 0.9;
            margin-bottom: 20px;
        }
        
        .topic-info {
            background: rgba(255, 255, 255, 0.15);
            border-radius: 15px;
            padding: 20px;
            margin-bottom: 30px;
            font-size: 0.9rem;
        }
        
        .topic-info h2 {
            color: #4facfe;
            margin-bottom: 10px;
        }
        
        .topic-info ul {
            padding-left: 25px;
        }
        
        .topic-info li {
            margin-bottom: 8px;
        }
        
        .screen {
            display: none;
        }
        
        .active {
            display: block;
        }
        
        .scenario-container {
            background: rgba(255, 255, 255, 0.1);
            border-radius: 15px;
            padding: 25px;
            margin-bottom: 30px;
            text-align: center;
        }
        
        .scenario-icon {
            font-size: 4rem;
            margin-bottom: 20px;
        }
        
        .scenario-text {
            font-size: 1.2rem;
            line-height: 1.5;
            margin-bottom: 25px;
        }
        
        .materials-container {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }
        
        .material-option {
            background: rgba(255, 255, 255, 0.1);
            border-radius: 15px;
            padding: 20px;
            text-align: center;
            cursor: pointer;
            transition: all 0.3s ease;
            border: 2px solid transparent;
        }
        
        .material-option:hover {
            transform: translateY(-5px);
            background: rgba(255, 255, 255, 0.15);
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);
        }
        
        .material-option.selected {
            border-color: #4facfe;
            background: rgba(79, 172, 254, 0.2);
        }
        
        .material-icon {
            font-size: 2rem;
            margin-bottom: 10px;
        }
        
        .material-name {
            font-weight: bold;
            margin-bottom: 10px;
        }
        
        .material-properties {
            font-size: 0.85rem;
            opacity: 0.9;
        }
        
        .feedback-container {
            display: none;
            padding: 20px;
            border-radius: 15px;
            margin-bottom: 30px;
            text-align: center;
        }
        
        .correct {
            background: rgba(46, 204, 113, 0.2);
            border: 2px solid #2ecc71;
        }
        
        .incorrect {
            background: rgba(231, 76, 60, 0.2);
            border: 2px solid #e74c3c;
        }
        
        .feedback-text {
            font-size: 1.4rem;
            margin-bottom: 15px;
        }
        
        .explanation {
            background: rgba(255, 255, 255, 0.1);
            border-radius: 10px;
            padding: 15px;
            font-size: 0.9rem;
            line-height: 1.5;
        }
        
        .progress-container {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
        }
        
        .progress-bar {
            flex-grow: 1;
            height: 12px;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 10px;
            overflow: hidden;
            margin: 0 20px;
        }
        
        .progress {
            height: 100%;
            background: linear-gradient(to right, #4facfe, #00f2fe);
            border-radius: 10px;
            width: 0%;
            transition: width 0.5s ease;
        }
        
        .buttons-container {
            display: flex;
            justify-content: center;
            gap: 20px;
        }
        
        button {
            padding: 15px 30px;
            border: none;
            border-radius: 10px;
            font-size: 1.1rem;
            font-weight: bold;
            cursor: pointer;
            transition: all 0.3s ease;
            background: linear-gradient(to right, #4facfe, #00f2fe);
            color: white;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);
        }
        
        button:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.3);
        }
        
        #next-button {
            display: none;
        }
        
        .results-container {
            text-align: center;
        }
        
        .score-display {
            font-size: 4rem;
            margin: 20px 0;
            background: linear-gradient(to right, #4facfe, #00f2fe);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        
        .results-message {
            font-size: 1.3rem;
            margin-bottom: 30px;
        }
        
        @media (max-width: 600px) {
            .container {
                padding: 15px;
            }
            
            h1 {
                font-size: 1.8rem;
            }
            
            .materials-container {
                grid-template-columns: 1fr;
            }
            
            button {
                padding: 12px 20px;
                font-size: 1rem;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <header>
            <h1>Material Classification Challenge</h1>
            <p class="subtitle">Test your understanding of materials for IB Design Technology</p>
        </header>
        
        <div class="topic-info">
            <h2>This game covers:</h2>
            <ul>
                <li><strong>A3.1:</strong> Material classification (metals, polymers, ceramics, composites, woods) and properties (strength, hardness, ductility, conductivity, density, stiffness, toughness, biodegradability, thermal/electrical properties)</li>
                <li><strong>B3.1:</strong> Material selection based on design criteria (cost, sustainability, manufacturability, availability, aesthetics)</li>
            </ul>
        </div>
        
        <div id="start-screen" class="screen active">
            <div class="scenario-container">
                <h2>Welcome to the Challenge!</h2>
                <p>You'll be presented with 10 real-world design scenarios. For each, select the best material based on the requirements.</p>
                <p>After your selection, you'll receive immediate feedback and explanations.</p>
            </div>
            
            <button id="start-button">Start Challenge</button>
        </div>
        
        <div id="game-screen" class="screen">
            <div class="progress-container">
                <span>Question: <span id="current-question">1</span>/10</span>
                <div class="progress-bar">
                    <div class="progress" id="progress"></div>
                </div>
                <span>Score: <span id="score">0</span></span>
            </div>
            
            <div class="scenario-container">
                <div class="scenario-icon" id="scenario-icon">🚲</div>
                <p class="scenario-text" id="scenario-text"></p>
            </div>
            
            <div class="materials-container" id="materials-container">
                <!-- Material options will be inserted here -->
            </div>
            
            <div class="feedback-container" id="feedback-container">
                <div class="feedback-text" id="feedback-text">Select a material</div>
                <div class="explanation" id="explanation"></div>
            </div>
            
            <div class="buttons-container">
                <button id="next-button">Next Question</button>
                <button id="restart-button" style="display: none;">Play Again</button>
            </div>
        </div>
        
        <div id="results-screen" class="screen">
            <h2>Challenge Complete!</h2>
            <div class="score-display" id="final-score">0/10</div>
            <p class="results-message">Great job! You've demonstrated your understanding of material selection.</p>
            <button id="play-again-button">Play Again</button>
        </div>
    </div>

    <script>
        // Scenario bank with realistic IB-level scenarios
        const scenarios = [
            {
                icon: "🚲",
                text: "Design a bicycle frame for urban commuting - needs low weight, high stiffness, recyclability, moderate cost.",
                correctMaterial: "Carbon fiber composite"
            },
            {
                icon: "🍽️",
                text: "Disposable cutlery for an event - needs biodegradability, low cost, sufficient stiffness for soup.",
                correctMaterial: "Bamboo"
            },
            {
                icon: "💻",
                text: "Laptop outer casing - needs impact resistance, electromagnetic shielding, lightweight, premium feel.",
                correctMaterial: "Aluminum 6061"
            },
            {
                icon: "🪑",
                text: "Outdoor park bench - needs UV resistance, low maintenance, vandal resistance, moderate cost.",
                correctMaterial: "High-density polyethylene (HDPE)"
            },
            {
                icon: "🦷",
                text: "Dental implant - needs biocompatibility, high strength, corrosion resistance, non-toxic.",
                correctMaterial: "Titanium"
            },
            {
                icon: "⚽",
                text: "Tennis racket frame - needs high stiffness, low weight, impact resistance, moderate cost.",
                correctMaterial: "Carbon fiber composite"
            },
            {
                icon: "📱",
                text: "Smartphone case - needs drop protection, slim design, aesthetic appeal, affordable production.",
                correctMaterial: "Polycarbonate"
            },
            {
                icon: "🏠",
                text: "Residential roof tiles for a hot climate - needs heat resistance, durability, weatherproofing, low cost.",
                correctMaterial: "Ceramic"
            },
            {
                icon: "🚗",
                text: "Automotive engine block - needs high thermal conductivity, wear resistance, light weight, strength under stress.",
                correctMaterial: "Aluminum alloy"
            },
            {
                icon: "🦴",
                text: "Bone replacement prosthesis - needs biocompatibility, mechanical strength, low weight, corrosion resistance.",
                correctMaterial: "Titanium alloy"
            },
            {
                icon: "🖼️",
                text: "Artwork display frame - needs durability, aesthetic appeal, lightweight, cost-effective manufacturing.",
                correctMaterial: "Bamboo composite"
            },
            {
                icon: "🦺",
                text: "Protective helmet for cycling - needs high impact resistance, lightweight, breathable material.",
                correctMaterial: "Polycarbonate"
            },
            {
                icon: "🥡",
                text: "Disposable food container - needs food safety, biodegradability, adequate strength, low cost.",
                correctMaterial: "Starch-based polymer"
            },
            {
                icon: "🏋️",
                text: "Gym weight plate - needs high tensile strength, wear resistance, non-slip surface, corrosion resistance.",
                correctMaterial: "Cast iron"
            },
            {
                icon: "🛠️",
                text: "Construction tool handle - needs durability, grip, lightweight, cost-effective manufacturing.",
                correctMaterial: "Fiberglass composite"
            }
        ];

        // Material options with properties
        const materials = [
            {name: "Carbon fiber composite", icon: "🪢", properties: ["Lightweight", "High stiffness"], type: "Composite"},
            {name: "Aluminum 6061", icon: "🧪", properties: ["Moderate weight", "Good strength", "Recyclable"], type: "Metal"},
            {name: "Bamboo", icon: "🎋", properties: ["Biodegradable", "Moderate stiffness", "Sustainable"], type: "Natural"},
            {name: "Steel", icon: "⚙️", properties: ["High strength", "Durable", "Recyclable"], type: "Metal"},
            {name: "Titanium", icon: "💎", properties: ["Biocompatible", "Corrosion resistant", "Strong"], type: "Metal"},
            {name: "Ceramic", icon: "🏺", properties: ["Heat resistant", "Durability", "Low thermal conductivity"], type: "Ceramic"},
            {name: "Polycarbonate", icon: "🧪", properties: ["Impact resistant", "Lightweight", "Transparent"], type: "Polymer"},
            {name: "High-density polyethylene (HDPE)", icon: "📦", properties: ["UV resistant", "Low maintenance", "Durable"], type: "Polymer"}
        ];

        // DOM elements
        const startScreen = document.getElementById('start-screen');
        const gameScreen = document.getElementById('game-screen');
        const resultsScreen = document.getElementById('results-screen');
        const startButton = document.getElementById('start-button');
        const nextButton = document.getElementById('next-button');
        const restartButton = document.getElementById('restart-button');
        const playAgainButton = document.getElementById('play-again-button');
        const currentQuestionElement = document.getElementById('current-question');
        const scoreElement = document.getElementById('score');
        const scenarioTextElement = document.getElementById('scenario-text');
        const scenarioIconElement = document.getElementById('scenario-icon');
        const materialsContainer = document.getElementById('materials-container');
        const feedbackContainer = document.getElementById('feedback-container');
        const feedbackTextElement = document.getElementById('feedback-text');
        const explanationElement = document.getElementById('explanation');
        const progressElement = document.getElementById('progress');
        const finalScoreElement = document.getElementById('final-score');

        let currentQuestionIndex = 0;
        let score = 0;
        let selectedMaterial = null;

        // Initialize the game
        function initGame() {
            currentQuestionIndex = 0;
            score = 0;
            updateUI();
            startScreen.classList.remove('active');
            gameScreen.classList.add('active');
            loadNextQuestion();
        }

        // Load next question
        function loadNextQuestion() {
            if (currentQuestionIndex >= 10) {
                showResults();
                return;
            }
            
            const scenario = scenarios[Math.floor(Math.random() * scenarios.length)];
            currentQuestionElement.textContent = currentQuestionIndex + 1;
            scoreElement.textContent = score;
            scenarioTextElement.textContent = scenario.text;
            scenarioIconElement.textContent = scenario.icon;

            // Clear previous materials
            materialsContainer.innerHTML = '';
            
            // Select 4 random materials for this question (excluding the correct one)
            const availableMaterials = [...materials];
            const correctMaterialIndex = availableMaterials.findIndex(mat => mat.name === scenario.correctMaterial);
            if (correctMaterialIndex !== -1) {
                availableMaterials.splice(correctMaterialIndex, 1); // Remove correct material
            }

            // Add the correct material to the list
            const correctMaterial = materials.find(mat => mat.name === scenario.correctMaterial);
            const selectedMaterials = [correctMaterial];
            
            // Fill remaining slots with random materials (excluding the correct one)
            for (let i = 0; i < 3 && availableMaterials.length > 0; i++) {
                const randomIndex = Math.floor(Math.random() * availableMaterials.length);
                selectedMaterials.push(availableMaterials.splice(randomIndex, 1)[0]);
            }

            // Shuffle materials
            shuffleArray(selectedMaterials);

            // Create material buttons
            selectedMaterials.forEach((material, index) => {
                const button = document.createElement('button');
                button.className = 'material-button';
                button.innerHTML = `
                    <div class="material-icon">${material.icon}</div>
                    <div>${material.name}</div>
                `;
                button.dataset.material = material.name;
                button.addEventListener('click', () => selectMaterial(material));
                materialsContainer.appendChild(button);
            });
            
            // Reset feedback
            feedbackContainer.style.display = 'none';
        }

        function shuffleArray(array) {
            for (let i = array.length - 1; i > 0; i--) {
                const j = Math.floor(Math.random() * (i + 1));
                [array[i], array[j]] = [array[j], array[i]];
            }
        }

        // Handle material selection
        function selectMaterial(material) {
            selectedMaterial = material;
            
            // Disable all buttons except the selected one
            const buttons = document.querySelectorAll('.material-button');
            buttons.forEach(button => {
                if (button.dataset.material === material.name) {
                    button.style.backgroundColor = '#a0d8ef';
                } else {
                    button.disabled = true;
                }
            });
            
            // Show feedback
            showFeedback(material);
        }

        function showFeedback(selectedMaterial) {
            const scenario = scenarios.find(s => s.correctMaterial === selectedMaterial.name);
            const isCorrect = selectedMaterial.name === scenario.correctMaterial;
            
            if (isCorrect) {
                feedbackTextElement.textContent = "✅ Correct!";
                score++;
                scoreElement.textContent = score;
            } else {
                feedbackTextElement.textContent = "❌ Incorrect";
            }
            
            // Show explanation
            let explanation = `The best material for this application is ${selectedMaterial.name} because it meets all the required properties:\n`;
            
            selectedMaterial.properties.forEach(prop => {
                explanation += `- ${prop}\n`;
            });
            
            if (isCorrect) {
                explanation += `\nThis choice aligns with IB Design Technology B3.1 principles for material selection.`;
            } else {
                const correctMaterial = materials.find(m => m.name === scenario.correctMaterial);
                explanation += `\nWhile ${selectedMaterial.name} has some good properties, ${correctMaterial.name} is better suited due to:\n`;
                correctMaterial.properties.forEach(prop => {
                    explanation += `- ${prop}\n`;
                });
            }
            
            explanationElement.textContent = explanation;
            feedbackContainer.style.display = 'block';
            
            // Enable next button
            nextButton.disabled = false;
        }

        function updateUI() {
            scoreElement.textContent = score;
            currentQuestionElement.textContent = currentQuestionIndex + 1;
            progressElement.style.width = `${((currentQuestionIndex) / 10) * 100}%`;
        }

        // Show results screen
        function showResults() {
            gameScreen.classList.remove('active');
            resultsScreen.classList.add('active');
            finalScoreElement.textContent = `${score}/10`;
        }

        // Event listeners
        startButton.addEventListener('click', initGame);
        nextButton.addEventListener('click', () => {
            currentQuestionIndex++;
            loadNextQuestion();
            
            // Re-enable buttons for next question
            const buttons = document.querySelectorAll('.material-button');
            buttons.forEach(button => {
                button.disabled = false;
                button.style.backgroundColor = '';
            });
            
            // Reset feedback display
            feedbackContainer.style.display = 'none';
            nextButton.disabled = true;
        });

        restartButton.addEventListener('click', initGame);
        playAgainButton.addEventListener('click', initGame);

        // Initialize the game on load
        window.onload = function() {
            updateUI();
        };
    </script>
</body>
</html>
