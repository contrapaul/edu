<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Material Selection Challenge</title>
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        
        body {
            background: linear-gradient(135deg, #1a2a6e, #b21f7d);
            color: #fff;
            min-height: 100vh;
            padding: 20px;
            display: flex;
            justify-content: center;
            align-items: center;
        }
        
        .container {
            background-color: rgba(30, 30, 50, 0.9);
            border-radius: 20px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
            width: 90%;
            max-width: 800px;
            padding: 30px;
            margin: 20px auto;
        }
        
        header {
            text-align: center;
            margin-bottom: 30px;
        }
        
        h1 {
            font-size: 2.5rem;
            margin-bottom: 10px;
            text-shadow: 0 2px 4px rgba(0,0,0,0.3);
        }
        
        .subtitle {
            font-size: 1.2rem;
            opacity: 0.9;
            max-width: 600px;
            margin: 0 auto;
        }
        
        .game-container {
            display: none;
        }
        
        .question-display {
            background-color: rgba(50, 50, 80, 0.7);
            border-radius: 15px;
            padding: 25px;
            margin-bottom: 30px;
            text-align: center;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);
        }
        
        .question-number {
            font-size: 1.2rem;
            color: #ffcc00;
            margin-bottom: 10px;
        }
        
        .scenario-icon {
            font-size: 3rem;
            margin: 15px 0;
        }
        
        .scenario-text {
            font-size: 1.4rem;
            line-height: 1.5;
            margin-bottom: 20px;
        }
        
        .materials-container {
            display: flex;
            flex-direction: column;
            gap: 15px;
            margin: 30px 0;
        }
        
        .material-option {
            background-color: rgba(70, 70, 120, 0.6);
            border: 2px solid #4a90e2;
            border-radius: 12px;
            padding: 20px;
            cursor: pointer;
            transition: all 0.3s ease;
            text-align: left;
        }
        
        .material-option:hover {
            transform: translateY(-5px);
            background-color: rgba(90, 90, 150, 0.8);
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.3);
        }
        
        .material-option.selected {
            border-color: #ffcc00;
            background-color: rgba(255, 204, 0, 0.2);
        }
        
        .material-name {
            font-size: 1.3rem;
            margin-bottom: 10px;
        }
        
        .material-properties {
            display: flex;
            justify-content: space-around;
            flex-wrap: wrap;
            gap: 10px;
        }
        
        .property {
            background-color: rgba(40, 60, 120, 0.7);
            padding: 8px 15px;
            border-radius: 20px;
            font-size: 0.9rem;
        }
        
        .feedback-container {
            display: none;
            text-align: center;
            margin: 25px 0;
            padding: 20px;
            border-radius: 15px;
            min-height: 100px;
            align-items: center;
            justify-content: center;
        }
        
        .feedback-correct {
            background-color: rgba(40, 160, 80, 0.3);
            border: 2px solid #50d070;
        }
        
        .feedback-incorrect {
            background-color: rgba(180, 40, 40, 0.3);
            border: 2px solid #ff6b6b;
        }
        
        .feedback-text {
            font-size: 1.2rem;
            margin: 15px 0;
        }
        
        .explanation {
            background-color: rgba(255, 255, 255, 0.1);
            border-radius: 10px;
            padding: 15px;
            margin-top: 15px;
            text-align: left;
        }
        
        .next-button {
            display: none;
            background-color: #4CAF50;
            color: white;
            border: none;
            padding: 15px 30px;
            font-size: 1.2rem;
            border-radius: 50px;
            cursor: pointer;
            margin: 20px auto;
            transition: all 0.3s ease;
        }
        
        .next-button:hover {
            background-color: #45a049;
            transform: scale(1.05);
        }
        
        .results-container {
            text-align: center;
            display: none;
        }
        
        .score-display {
            font-size: 3rem;
            color: #ffcc00;
            margin: 20px 0;
        }
        
        .play-again-button {
            background-color: #4CAF50;
            color: white;
            border: none;
            padding: 15px 40px;
            font-size: 1.2rem;
            border-radius: 50px;
            cursor: pointer;
            margin-top: 30px;
            transition: all 0.3s ease;
        }
        
        .play-again-button:hover {
            background-color: #45a049;
            transform: scale(1.05);
        }
        
        .how-to-play {
            background-color: rgba(50, 50, 80, 0.7);
            border-radius: 15px;
            padding: 25px;
            margin-top: 30px;
            font-size: 1.1rem;
            line-height: 1.6;
        }
        
        .how-to-play h2 {
            color: #ffcc00;
            margin-bottom: 15px;
        }
        
        .topics-list {
            display: flex;
            justify-content: space-around;
            flex-wrap: wrap;
            gap: 20px;
            margin: 20px 0;
        }
        
        .topic-box {
            background-color: rgba(70, 130, 180, 0.5);
            border-radius: 10px;
            padding: 15px;
            width: 40%;
            min-width: 250px;
        }
        
        .topic-title {
            font-size: 1.4rem;
            color: #ffcc00;
            margin-bottom: 10px;
        }
        
        .topic-content {
            line-height: 1.5;
        }
        
        .material-type-icon {
            display: inline-block;
            width: 30px;
            height: 30px;
            border-radius: 50%;
            margin-right: 10px;
            vertical-align: middle;
        }
        
        .metal { background-color: #a8a8a8; }
        .polymer { background-color: #ff9900; }
        .ceramic { background-color: #d32f2f; }
        .composite { background-color: #64b5f6; }
        .wood { background-color: #795548; }
        
        @media (max-width: 768px) {
            .container {
                padding: 15px;
            }
            
            h1 {
                font-size: 2rem;
            }
            
            .scenario-text {
                font-size: 1.2rem;
            }
            
            .material-option {
                padding: 15px;
            }
            
            .topic-box {
                width: 90%;
                min-width: auto;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <header>
            <h1>Material Selection Challenge</h1>
            <p class="subtitle">Test your knowledge of material properties and selection for IB Design Technology</p>
        </header>
        
        <div id="start-screen" class="game-container">
            <div class="how-to-play">
                <h2>How to Play</h2>
                <p>You'll be presented with design scenarios that require specific material properties. Your task is to select the best material for each scenario.</p>
                
                <div class="topics-list">
                    <div class="topic-box">
                        <div class="topic-title">Topic A3.1: Material Classification</div>
                        <p>Metals, polymers, ceramics, composites, and woods - their properties include strength, hardness, ductility, conductivity, density, stiffness, toughness, biodegradability, thermal/electrical properties.</p>
                    </div>
                    
                    <div class="topic-box">
                        <div class="topic-title">Topic B3.1: Material Selection</div>
                        <p>Consider factors like cost, sustainability, manufacturability, availability, and aesthetics when selecting materials for your design.</p>
                    </div>
                </div>
            </div>
            
            <button id="start-button" class="play-again-button">Start Challenge</button>
        </div>
        
        <div id="game-screen" class="game-container">
            <div class="question-display">
                <div class="question-number">Question <span id="current-question">1</span>/10</div>
                <div class="scenario-icon" id="scenario-icon">🚲</div>
                <div class="scenario-text" id="scenario-text">Design a bicycle frame for urban commuting - needs low weight, high stiffness, recyclability, moderate cost.</div>
            </div>
            
            <div class="materials-container">
                <div class="material-option" data-material="carbon-fiber">
                    <div class="material-name">Carbon Fiber Composite</div>
                    <div class="material-properties">
                        <span class="property">Low Weight</span>
                        <span class="property">High Stiffness</span>
                        <span class="property">Recyclable</span>
                        <span class="property">Moderate Cost</span>
                    </div>
                </div>
                
                <div class="material-option" data-material="aluminum">
                    <div class="material-name">Aluminum 6061</div>
                    <div class="material-properties">
                        <span class="property">Low Weight</span>
                        <span class="property">High Stiffness</span>
                        <span class="property">Recyclable</span>
                        <span class="property">Moderate Cost</span>
                    </div>
                </div>
                
                <div class="material-option" data-material="bamboo">
                    <div class="material-name">Bamboo</div>
                    <div class="material-properties">
                        <span class="property">Low Weight</span>
                        <span class="property">Moderate Stiffness</span>
                        <span class="property">Biodegradable</span>
                        <span class="property">Low Cost</span>
                    </div>
                </div>
                
                <div class="material-option" data-material="steel">
                    <div class="material-name">Steel</div>
                    <div class="material-properties">
                        <span class="property">High Strength</span>
                        <span class="property">Moderate Stiffness</span>
                        <span class="property">Recyclable</span>
                        <span class="property">Low Cost</span>
                    </div>
                </div>
            </div>
            
            <div id="feedback-container" class="feedback-container">
                <div class="feedback-text" id="feedback-text"></div>
                <div class="explanation" id="explanation"></div>
            </div>
            
            <button id="next-button" class="next-button">Next Question</button>
        </div>
        
        <div id="results-screen" class="results-container">
            <h2>Challenge Complete!</h2>
            <div class="score-display">Your Score: <span id="final-score">0/10</span></div>
            <p>You've demonstrated your knowledge of material selection for design challenges.</p>
            <button id="play-again-button" class="play-again-button">Play Again</button>
        </div>
    </div>

    <script>
        // Material data
        const materials = [
            {
                name: "Carbon Fiber Composite",
                properties: ["Low Weight", "High Stiffness", "Recyclable", "Moderate Cost"],
                type: "composite"
            },
            {
                name: "Aluminum 6061",
                properties: ["Low Weight", "High Stiffness", "Recyclable", "Moderate Cost"],
                type: "metal"
            },
            {
                name: "Bamboo",
                properties: ["Low Weight", "Moderate Stiffness", "Biodegradable", "Low Cost"],
                type: "wood"
            },
            {
                name: "Steel",
                properties: ["High Strength", "Moderate Stiffness", "Recyclable", "Low Cost"],
                type: "metal"
            }
        ];

        // Scenario bank with 15+ scenarios
        const scenarios = [
            {
                icon: "🚲",
                text: "Design a bicycle frame for urban commuting - needs low weight, high stiffness, recyclability, moderate cost.",
                correctMaterial: "carbon-fiber",
                explanation: "Carbon fiber composite is ideal for bike frames because it's extremely lightweight while providing excellent stiffness-to-weight ratio. It's also fully recyclable and has a moderate cost compared to other advanced composites."
            },
            {
                icon: "🍽️",
                text: "Design disposable cutlery for an event - needs biodegradability, low cost, sufficient stiffness for soup.",
                correctMaterial: "bamboo",
                explanation: "Bamboo is naturally biodegradable and costs less than many other sustainable options. While it's not the stiffest material, it provides adequate strength for typical use in food service."
            },
            {
                icon: "💻",
                text: "Design laptop outer casing - needs impact resistance, electromagnetic shielding, lightweight, premium feel.",
                correctMaterial: "aluminum",
                explanation: "Aluminum is an excellent choice because it's lightweight and can be machined to a high finish for a premium look. It also provides good protection against impacts and has some electrical conductivity properties."
            },
            {
                icon: "🪑",
                text: "Design outdoor park bench - needs UV resistance, low maintenance, vandal resistance, moderate cost.",
                correctMaterial: "polymer",
                explanation: "High-density polyethylene is ideal for outdoor benches because it's UV-resistant, doesn't require maintenance, and is extremely durable against vandalism. It's also affordable."
            },
            {
                icon: "🦷",
                text: "Design a dental implant - needs biocompatibility, high strength, corrosion resistance, non-toxic.",
                correctMaterial: "titanium",
                explanation: "Titanium is the gold standard for medical implants due to its excellent biocompatibility and corrosion resistance. It's also strong enough to handle mechanical stresses in the body."
            },
            {
                icon: "⚽",
                text: "Design a football helmet padding - needs impact absorption, lightweight, durability.",
                correctMaterial: "polycarbonate",
                explanation: "Polycarbonate is an excellent choice for this application because it can absorb high-impact forces while remaining lightweight. It's also highly durable and resistant to cracking."
            },
            {
                icon: "🚗",
                text: "Design car interior trim - needs aesthetic appeal, impact resistance, easy maintenance.",
                correctMaterial: "polymer",
                explanation: "Polymer materials like polypropylene are perfect for this application as they're aesthetically pleasing, easy to mold into complex shapes, and highly resistant to impacts."
            },
            {
                icon: "🏗️",
                text: "Design a bridge deck - needs high strength, weather resistance, cost-effective.",
                correctMaterial: "concrete",
                explanation: "Concrete is the most suitable choice for bridge decks because it's extremely strong, naturally weather-resistant, and cost-effective. It also allows for large structural elements."
            },
            {
                icon: "📱",
                text: "Design a smartphone case - needs drop protection, thin profile, affordable.",
                correctMaterial: "polymer",
                explanation: "Polymer materials like polycarbonate or TPU offer excellent drop protection while remaining thin and affordable. They're also easy to mold into complex designs."
            },
            {
                icon: "🧺",
                text: "Design a picnic basket - needs lightweight, water-resistant, durable.",
                correctMaterial: "wood",
                explanation: "Wood is an excellent choice for this application as it's naturally durable and can be treated to be water-resistant. It also provides the aesthetic appeal needed for outdoor use."
            },
            {
                icon: "🔬",
                text: "Design a microscope slide holder - needs high precision, chemical resistance, lightweight.",
                correctMaterial: "ceramic",
                explanation: "Ceramic materials are ideal here because they offer excellent chemical resistance and can be machined to extremely precise tolerances while remaining lightweight."
            },
            {
                icon: "🎓",
                text: "Design a desk for school students - needs durability, light weight for portability, low cost.",
                correctMaterial: "polymer",
                explanation: "Polymer materials like high-density polyethylene are durable enough to withstand daily use in schools while being lightweight and affordable."
            },
            {
                icon: "🚁",
                text: "Design a helicopter rotor blade - needs high strength-to-weight ratio, fatigue resistance.",
                correctMaterial: "carbon-fiber composite",
                explanation: "Carbon fiber composites provide the ideal combination of high strength and low weight required for rotor blades. They also offer excellent fatigue resistance needed in rotating applications."
            },
            {
                icon: "🎧",
                text: "Design noise-canceling headphones - needs sound isolation, lightweight, comfort.",
                correctMaterial: "polymer",
                explanation: "Polymer materials are perfect here because they're lightweight and can be designed with acoustic properties to enhance sound isolation. They also provide comfort for extended wear."
            },
            {
                icon: "🌡️",
                text: "Design a heat exchanger in an HVAC system - needs high thermal conductivity, corrosion resistance.",
                correctMaterial: "aluminum",
                explanation: "Aluminum is ideal for heat exchangers because it has excellent thermal conductivity and can be treated to resist corrosion. It's also lightweight and cost-effective."
            }
        ];

        // Game state
        let currentQuestion = 0;
        let score = 0;
        let gameActive = false;

        // DOM elements
        const startScreen = document.getElementById('start-screen');
        const gameScreen = document.getElementById('game-screen');
        const resultsScreen = document.getElementById('results-screen');
        const startButton = document.getElementById('start-button');
        const nextButton = document.getElementById('next-button');
        const playAgainButton = document.getElementById('play-again-button');
        const currentQuestionElement = document.getElementById('current-question');
        const scenarioText = document.getElementById('scenario-text');
        const scenarioIcon = document.getElementById('scenario-icon');
        const feedbackContainer = document.getElementById('feedback-container');
        const feedbackText = document.getElementById('feedback-text');
        const explanation = document.getElementById('explanation');

        // Initialize game
        startButton.addEventListener('click', () => {
            startScreen.style.display = 'none';
            gameScreen.style.display = 'block';
            currentQuestion = 0;
            score = 0;
            nextQuestion();
        });

        playAgainButton.addEventListener('click', () => {
            resultsScreen.style.display = 'none';
            startScreen.style.display = 'block';
        });

        // Event listeners for material selection
        document.querySelectorAll('.material-option').forEach(option => {
            option.addEventListener('click', (e) => {
                if (!gameActive) return;
                
                const selectedMaterial = e.currentTarget.dataset.material;
                const correctMaterial = scenarios[currentQuestion].correctMaterial;
                
                if (selectedMaterial === correctMaterial) {
                    feedbackText.textContent = "✓ Correct!";
                    score++;
                } else {
                    feedbackText.textContent = "✗ Incorrect";
                }
                
                explanation.innerHTML = `<strong>Explanation:</strong> ${scenarios[currentQuestion].explanation}`;
                gameActive = false;
                nextButton.style.display = 'block';
            });
        });

        // Next button
        nextButton.addEventListener('click', () => {
            if (currentQuestion < 9) {
                currentQuestion++;
                nextQuestion();
            } else {
                endGame();
            }
        });

        function nextQuestion() {
            gameActive = true;
            nextButton.style.display = 'none';
            
            const scenario = scenarios[currentQuestion];
            scenarioText.textContent = scenario.text;
            scenarioIcon.textContent = scenario.icon;
            currentQuestionElement.textContent = (currentQuestion + 1).toString();
            
            // Reset material options
            document.querySelectorAll('.material-option').forEach(option => {
                option.style.backgroundColor = '';
            });
            
            feedbackContainer.style.display = 'none';
        }

        function endGame() {
            gameScreen.style.display = 'none';
            resultsScreen.style.display = 'block';
            document.getElementById('final-score').textContent = `${score}/10`;
        }
    </script>
</body>
</html>
